<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:cfg="using:Mesen.Config"
	xmlns:c="using:Mesen.Controls"
	xmlns:dc="using:Mesen.Debugger.Controls"
	xmlns:l="using:Mesen.Localization"
	mc:Ignorable="d"
  Design.Width="200"
  Design.Height="600"
	VerticalAlignment="Stretch"
	HorizontalAlignment="Stretch"
	x:DataType="cfg:WsEventViewerConfig"
	x:Class="Mesen.Debugger.Views.WsEventViewerConfigView"
>
	<Design.DataContext>
		<cfg:WsEventViewerConfig />
	</Design.DataContext>

	<StackPanel>
		<Grid ColumnDefinitions="10, 1*, 10, 1*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
			<c:OptionSection Header="{l:Translate secPpuWrites}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0" />
			<c:OptionSection Header="{l:Translate secPpuReads}" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"  Margin="10 0 0 0" />
			<StackPanel Grid.Column="1" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="{l:Translate lblScroll}" Config="{Binding PpuScrollWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblWindow}" Config="{Binding PpuWindowWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblPalette}" Config="{Binding PpuPaletteWrite}" />
				<dc:EventViewerCategoryControl Text="VRAM" Config="{Binding PpuVramWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblOthers}" Config="{Binding PpuOtherWrite}" />
			</StackPanel>
			<StackPanel Grid.Column="3" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="{l:Translate lblScroll}" Config="{Binding PpuScrollRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblWindow}" Config="{Binding PpuWindowRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblPalette}" Config="{Binding PpuPaletteRead}" />
				<dc:EventViewerCategoryControl Text="VRAM" Config="{Binding PpuVramRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblOthers}" Config="{Binding PpuOtherRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblVCounter}" Config="{Binding PpuVCounterRead}" />
			</StackPanel>
		</Grid>
		
		<Grid ColumnDefinitions="10, 1*, 10, 1*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0 15 0 0">
			<c:OptionSection Header="{l:Translate secPortWrites}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0" />
			<c:OptionSection Header="{l:Translate secPortReads}" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"  Margin="10 0 0 0" />
			<StackPanel Grid.Column="1" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="{l:Translate lblAudio}" Config="{Binding AudioWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblCart}" Config="{Binding CartWrite}" />
				<dc:EventViewerCategoryControl Text="DMA" Config="{Binding DmaWrite}" />
				<dc:EventViewerCategoryControl Text="IEEPROM" Config="{Binding EepromWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblInput}" Config="{Binding InputWrite}" />
				<dc:EventViewerCategoryControl Text="IRQ" Config="{Binding IrqWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblSerial}" Config="{Binding SerialWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblTimer}" Config="{Binding TimerWrite}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblOthers}" Config="{Binding OtherWrite}" />
			</StackPanel>
			<StackPanel Grid.Column="3" Grid.Row="1">
				<dc:EventViewerCategoryControl Text="{l:Translate lblAudio}" Config="{Binding AudioRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblCart}" Config="{Binding CartRead}" />
				<dc:EventViewerCategoryControl Text="DMA" Config="{Binding DmaRead}" />
				<dc:EventViewerCategoryControl Text="IEEPROM" Config="{Binding EepromRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblInput}" Config="{Binding InputRead}" />
				<dc:EventViewerCategoryControl Text="IRQ" Config="{Binding IrqRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblSerial}" Config="{Binding SerialRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblTimer}" Config="{Binding TimerRead}" />
				<dc:EventViewerCategoryControl Text="{l:Translate lblOthers}" Config="{Binding OtherRead}" />
			</StackPanel>
		</Grid>

		<c:OptionSection Header="{l:Translate secOtherEvents}" />
		<StackPanel>
			<dc:EventViewerCategoryControl Text="IRQ" Config="{Binding Irq}" />
			<dc:EventViewerCategoryControl Text="{l:Translate lblMarkedBreakpoints}" Config="{Binding MarkedBreakpoints}" />
		</StackPanel>

		<CheckBox Margin="0 10 0 0" IsChecked="{Binding ShowPreviousFrameEvents}" Content="{l:Translate chkShowPreviousFrameEvents}" />
	</StackPanel>
</UserControl>
